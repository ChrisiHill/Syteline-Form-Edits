               <ScriptLine>Imports Microsoft.VisualBasic</ScriptLine>
               <ScriptLine>Imports Mongoose.IDO.Protocol</ScriptLine>
               <ScriptLine>Imports Mongoose.Scripting</ScriptLine>
               <ScriptLine />
               <ScriptLine>Namespace SyteLine.FormScripts</ScriptLine>
               <ScriptLine>    Public Class CopyItems</ScriptLine>
               <ScriptLine>        Inherits FormScript</ScriptLine>
               <ScriptLine />
               <ScriptLine>        Public Sub ItemCopyDone()</ScriptLine>
               <ScriptLine>            Dim strRS As String</ScriptLine>
               <ScriptLine>            If ThisForm.Variables("Process").Value = "C" Then</ScriptLine>
               <ScriptLine>                IF ThisForm.Variables("iNoPreview").Value = "1" OR ThisForm.Variables("vCount").Value &lt;&gt; "0" Then</ScriptLine>
               <ScriptLine>                    strRS = ThisForm.CallGlobalScript("MsgApp", "Clear", "Prompt", "SuccessFailure", _</ScriptLine>
               <ScriptLine>                        "mI=#Processed", ThisForm.Variables("vCount").Value, _</ScriptLine>
               <ScriptLine>                        "STRINGS(sItem)", "", "", "", "", "", "", "", "", "", "", "", "", "", "")</ScriptLine>
               <ScriptLine>                End If</ScriptLine>
               <ScriptLine>            Else</ScriptLine>
               <ScriptLine>                strRS = ThisForm.CallGlobalScript("MsgApp", "Clear", "NoPrompt", "SuccessFailure", _</ScriptLine>
               <ScriptLine>                    "mI=#Displayed", CStr(ThisForm.PrimaryIDOCollection.GetNumEntries), _</ScriptLine>
               <ScriptLine>                    "STRINGS(sItem)", "", "", "", "", "", "", "", "", "", "", "", "", "", "")</ScriptLine>
               <ScriptLine />
               <ScriptLine>                  If Application.Variables("SuppressOKInformationalMessages").GetValueOfBoolean(False) Then</ScriptLine>
               <ScriptLine>                     Application.ShowMessage(ThisForm.Variables("PromptMsg").Value, "", wsMessageStyle.wsInformation, wsMessageDisplay.wsToast)</ScriptLine>
               <ScriptLine>                  Else</ScriptLine>
               <ScriptLine>                     Application.ShowMessage(ThisForm.Variables("PromptMsg").Value, wsMessageStyle.wsInformation)</ScriptLine>
               <ScriptLine>                  End If</ScriptLine>
               <ScriptLine />
               <ScriptLine>            End If</ScriptLine>
               <ScriptLine>        End Sub</ScriptLine>
               <ScriptLine />
               <ScriptLine />
               <ScriptLine>        Public Sub ItemCopyStart()</ScriptLine>
               <ScriptLine>            Dim strRS As String</ScriptLine>
               <ScriptLine>            Dim i As Integer</ScriptLine>
               <ScriptLine>            Dim iNoPreview As Integer</ScriptLine>
               <ScriptLine>            iNoPreview = 0</ScriptLine>
               <ScriptLine>            ThisForm.Variables("iNoPreview").Value = CSTR(iNoPreview)</ScriptLine>
               <ScriptLine />
               <ScriptLine>            If ThisForm.Variables("Process").Value = "P" Then</ScriptLine>
               <ScriptLine>                ThisForm.GenerateEvent("StdFormRefresh")</ScriptLine>
               <ScriptLine>                ThisForm.GenerateEvent("ItemCopyDone")</ScriptLine>
               <ScriptLine>                Exit Sub</ScriptLine>
               <ScriptLine>            End If</ScriptLine>
               <ScriptLine />
               <ScriptLine>            ThisForm.Variables("vCount").Value = "0"</ScriptLine>
               <ScriptLine />
               <ScriptLine>            If ThisForm.PrimaryIDOCollection.GetNumEntries = 0 Then</ScriptLine>
               <ScriptLine>                iNoPreview = 1  '  User did not select Preview button, process all records</ScriptLine>
               <ScriptLine>                ThisForm.Variables("iNoPreview").Value = CSTR(iNoPreview)</ScriptLine>
               <ScriptLine>                ThisForm.Variables("Process").Value = "P" ' display the grid without processing</ScriptLine>
               <ScriptLine>                ThisForm.GenerateEvent("StdFormRefresh")</ScriptLine>
               <ScriptLine>                ThisForm.Variables("Process").Value = "C" ' reset the value</ScriptLine>
               <ScriptLine>                If ThisForm.PrimaryIDOCollection.GetNumEntries &lt;&gt; 0 Then</ScriptLine>
               <ScriptLine>                    For i = 0 To ThisForm.PrimaryIDOCollection.GetNumEntries - 1</ScriptLine>
               <ScriptLine>                        ' Select for Comitting only those rows without an error:</ScriptLine>
               <ScriptLine>                        If ThisForm.PrimaryIDOCollection.GetObjectProperty("DerMessage", i) = "" Then _</ScriptLine>
               <ScriptLine>                            ThisForm.PrimaryIDOCollection.SetObjectPropertyPlusModifyRefresh("UbSelect", i, "1")</ScriptLine>
               <ScriptLine>                    Next</ScriptLine>
               <ScriptLine>                Else</ScriptLine>
               <ScriptLine>                    ThisForm.GenerateEvent("ItemCopyDone")</ScriptLine>
               <ScriptLine>                End If</ScriptLine>
               <ScriptLine>            End If</ScriptLine>
               <ScriptLine />
               <ScriptLine>            If ThisForm.PrimaryIDOCollection.GetNumEntries &lt;&gt; 0 Then</ScriptLine>
               <ScriptLine>                ThisForm.GenerateEvent("PromptMessage")</ScriptLine>
               <ScriptLine>            End If</ScriptLine>
               <ScriptLine>        End Sub</ScriptLine>
               <ScriptLine />
               <ScriptLine>        Sub EnableDisable()</ScriptLine>
               <ScriptLine>            Dim oCache As IWSIDOCollection</ScriptLine>
               <ScriptLine />
               <ScriptLine>            oCache = ThisForm.PrimaryIDOCollection</ScriptLine>
               <ScriptLine />
               <ScriptLine>            ' if either the From Item or To Item fields change then clear out the grid</ScriptLine>
               <ScriptLine>            ThisForm.PrimaryIDOCollection.RemoveEntries(0, -1)</ScriptLine>
               <ScriptLine>        End Sub</ScriptLine>
               <ScriptLine />
               <ScriptLine>        Sub ProcessRecords()</ScriptLine>
               <ScriptLine>            Dim i As Integer</ScriptLine>
               <ScriptLine>            'Dim NewItem As String</ScriptLine>
               <ScriptLine>            Dim iCount As Integer</ScriptLine>
               <ScriptLine>            Dim iRetVal As Integer</ScriptLine>
               <ScriptLine>            Dim idx As Integer</ScriptLine>
               <ScriptLine>            Dim sel As String</ScriptLine>
               <ScriptLine />
               <ScriptLine>            ThisForm.Variables("vCopyUDF").Value = ThisForm.Components("CopyUDFEdit").Text</ScriptLine>
               <ScriptLine>            ThisForm.Variables("vCopyBOM").Value = ThisForm.Components("CopyBOMEdit").Text</ScriptLine>
               <ScriptLine>            ThisForm.Variables("vCopyLoc").Value = ThisForm.Components("CopyLocationEdit").Text</ScriptLine>
               <ScriptLine>            ThisForm.Variables("vEffectDate").Value = ThisForm.Components("EffectDateEdit").Value</ScriptLine>
               <ScriptLine />
               <ScriptLine>            iCount = 0</ScriptLine>
               <ScriptLine>            ThisForm.PrimaryIDOCollection.First()</ScriptLine>
               <ScriptLine>            For i = 1 To ThisForm.PrimaryIDOCollection.GetNumEntries</ScriptLine>
               <ScriptLine />
               <ScriptLine>                idx = ThisForm.PrimaryIDOCollection.GetCurrentObjectIndex</ScriptLine>
               <ScriptLine>                sel = ThisForm.PrimaryIDOCollection.GetObjectProperty("UbSelect", idx)</ScriptLine>
               <ScriptLine>                If sel = "1" Then</ScriptLine>
               <ScriptLine>                    ThisForm.Variables("vFromItem").Value = ThisForm.PrimaryIDOCollection.GetObjectProperty("Item", idx)</ScriptLine>
               <ScriptLine>                    ThisForm.Variables("vNewItem").Value = ThisForm.PrimaryIDOCollection.GetObjectProperty("AltItem", idx)</ScriptLine>
               <ScriptLine>                    ThisForm.Variables("vPlanFlag").Value = ThisForm.PrimaryIDOCollection.GetObjectProperty("PlanFlag", idx)</ScriptLine>
               <ScriptLine>                    ThisForm.Variables("vFeatStr").Value = ThisForm.PrimaryIDOCollection.GetObjectProperty("FeatStr", idx)</ScriptLine>
               <ScriptLine>                    ThisForm.Variables("vBackEndMessage").Value = ""</ScriptLine>
               <ScriptLine />
               <ScriptLine>                    iRetVal = ThisForm.GenerateEvent("CallItemCopyDataSp")</ScriptLine>
               <ScriptLine>                    If iRetVal = 0 Then</ScriptLine>
               <ScriptLine>                        ThisForm.PrimaryIDOCollection.RemoveEntries(ThisForm.PrimaryIDOCollection.GetCurrentObjectIndex, 1)</ScriptLine>
               <ScriptLine>                        iCount = iCount + 1</ScriptLine>
               <ScriptLine>                    Else</ScriptLine>
               <ScriptLine>                        ThisForm.PrimaryIDOCollection.SetCurrentObjectPropertyPlusModifyRefresh("DerMessage", ThisForm.Variables("vBackEndMessage").Value)</ScriptLine>
               <ScriptLine>                        ThisForm.PrimaryIDOCollection.Next()</ScriptLine>
               <ScriptLine>                    End If</ScriptLine>
               <ScriptLine>                Else</ScriptLine>
               <ScriptLine>                    ThisForm.PrimaryIDOCollection.Next()</ScriptLine>
               <ScriptLine>                End If</ScriptLine>
               <ScriptLine />
               <ScriptLine>            Next i</ScriptLine>
               <ScriptLine>            ThisForm.Variables("vCount").Value = CStr(iCount)</ScriptLine>
               <ScriptLine>        End Sub</ScriptLine>
               <ScriptLine>    End Class</ScriptLine>
               <ScriptLine>End Namespace</ScriptLine>
            </ScriptLines>
         </Script>
      </Form>
   </Forms>
</FormsAndObjectsExport>